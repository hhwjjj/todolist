{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:path:default",
    "sql:default",
    "sql:allow-execute",
    "fs:default",
    "fs:read-all",
    "fs:write-all",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://api.deepseek.com/**" }
      ]
    }
  ]
}
